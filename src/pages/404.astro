---
import MainGridLayout from "@layouts/MainGridLayout.astro";
---

<MainGridLayout title="页面未找到" description="请求的页面不存在或已经移动。" noIndex={true}>
	<section class="card-base flex min-h-[28rem] flex-col items-center justify-center rounded-[var(--radius-large)] px-6 py-12 text-center">
		<p class="text-[8rem] font-bold leading-none text-[var(--primary)]" aria-hidden="true">404</p>
		<h1 class="mt-6 text-3xl font-bold text-90">页面未找到</h1>
		<p class="mt-3 text-75">请求的页面不存在、已被移除，或者地址有误。</p>
		<a
			href="/"
			class="btn-regular mt-8 rounded-lg bg-[var(--btn-regular-bg)] px-5 py-2 font-medium text-[var(--primary)] hover:bg-[var(--btn-regular-bg-hover)]"
		>
			返回主页
		</a>
	</section>
</MainGridLayout>
